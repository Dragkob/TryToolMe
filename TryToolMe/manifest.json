{
  "manifest_version": 3,
  "name": "TryToolMe",
  "version": "1.0",
  "description": "A browser extension for TryHackMe: room timelines, public-profile insights, and capability score details.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://tryhackme.com/room/*",
    "https://tryhackme.com/p/*",
    "https://tryhackme.com/api/*",
    "https://status-api.vm.tryhackme.com/*"
  ],
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tryhackme.com/room/*",
        "https://tryhackme.com/p/*"
      ],
      "js": [ "js/content.js" ]
    }
  ],
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}